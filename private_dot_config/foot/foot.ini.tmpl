{{- $font := "IBM Plex Mono" -}}
{{- $size := "size=9" -}}
{{- if eq .chezmoi.hostname "home" }}{{$font = "UW Ttyp0"}}{{- $size := "pixelsize=15" -}}{{ end -}}
font={{- $font -}}:style=Regular:{{- $size}}
font-bold={{- $font -}}:style=Bold:{{- $size}}
font-bold-italic={{- $font -}}:style=Italic:{{- $size}}
font-italic={{- $font -}}:style=Italic:{{- $size}}
dpi-aware=yes

[scrollback]
lines = 0

[mouse]
hide-when-typing=yes

[main]
include=/usr/share/foot/themes/starlight

[cursor]
blink=no

